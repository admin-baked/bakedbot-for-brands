{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:embed && npm run check:structure && next build --turbopack",
    "build:embed": "tsup",
    "start": "next start",
    "postinstall": "node scripts/patch-punycode-deprecation.mjs",
    "deploy:apphosting:rollout": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-apphosting-rollout.ps1",
    "deploy:firebase:local": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-firebase-production.ps1",
    "lint": "next lint",
    "test": "node scripts/run-jest.cjs",
    "test:watch": "node scripts/run-jest.cjs --watch",
    "test:coverage": "node scripts/run-jest.cjs --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:codegen": "playwright codegen http://localhost:3000",
    "deploy-functions": "firebase deploy --only functions",
    "init-embeddings": "npx tsx scripts/init-review-embeddings.ts",
    "audit": "bash ./scripts/quick-audit.sh",
    "audit:deep": "bash ./scripts/audit-code.sh",
    "pre-publish": "bash ./scripts/pre-publish.sh",
    "check:structure": "node scripts/check-app-structure.mjs",
    "check:types": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc --noEmit --incremental false",
    "check:lint": "echo 'Skipping lint check due to known next-16 incompatibility' && exit 0",
    "check:routes": "node scripts/check-routes.mjs",
    "check:all": "npm run check:structure && npm run check:types && npm run check:lint",
    "check:env": "node -e \"import('./dist/config/env.js').catch(e => { console.error(e); process.exit(1) })\"",
    "push": "bash scripts/safe-push.sh",
    "dev:with-sa": "powershell -ExecutionPolicy Bypass -File ./scripts/start-dev-with-firebase.ps1",
    "migrate:artifacts": "npx tsx scripts/migrate-to-unified-artifacts.ts",
    "migrate:artifacts:execute": "npx tsx scripts/migrate-to-unified-artifacts.ts --execute",
    "audit:indexes": "node scripts/audit-indexes.mjs",
    "audit:indexes:create": "node scripts/audit-indexes.mjs --auto-create",
    "setup:secrets": "node scripts/setup-secrets.mjs",
    "setup:secrets:deploy": "node scripts/setup-secrets.mjs --deploy",
    "setup:artifact-repo": "node scripts/setup-playbook-artifact-repo.mjs",
    "audit:schema": "node scripts/audit-schema.mjs",
    "audit:schema:org": "node scripts/audit-schema.mjs --orgId",
    "seed:test": "node scripts/seed-test-data.mjs",
    "seed:test:clean": "node scripts/seed-test-data.mjs --clean",
    "seed:super-user-playbooks": "node scripts/seed-super-user-playbooks.mjs",
    "generate:component": "node scripts/generate.mjs component",
    "generate:action": "node scripts/generate.mjs action",
    "generate:route": "node scripts/generate.mjs route",
    "generate:cron": "node scripts/generate.mjs cron",
    "fix:build": "node scripts/fix-build.mjs",
    "fix:build:apply": "node scripts/fix-build.mjs --apply",
    "test:security": "node scripts/test-security-rules.mjs",
    "check:compliance": "node scripts/check-compliance.mjs",
    "audit:consistency": "node scripts/audit-consistency.mjs",
    "setup:monitoring": "node scripts/setup-monitoring.mjs",
    "audit:costs": "node scripts/audit-query-cost.mjs",
    "provision:ny-outreach": "node scripts/provision-ny-outreach.mjs",
    "switch-model": "node scripts/switch-claude-model.mjs",
    "audit:agent-tools": "node scripts/audit-agent-tools.mjs",
    "remotion:bundle": "node scripts/bundle-remotion.mjs",
    "smoke:proactive": "node ./scripts/run-proactive-smoke.cjs",
    "smoke:analytics": "node --env-file=.env.local scripts/smoke-analytics.mjs",
    "firebase:apphosting": "node scripts/firebase-apphosting.mjs"
  },
