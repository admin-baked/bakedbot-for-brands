{
  "mcpServers": {
    "cognee-experiment": {
      "type": "stdio",
      "command": "python",
      "args": [
        "scripts/cognee-experiment/mcp_server.py"
      ],
      "env": {
        "ENABLE_BACKEND_ACCESS_CONTROL": "false"
      }
    },
    "reddit": {
      "type": "stdio",
      "command": "uvx",
      "args": ["reddit-no-auth-mcp-server"],
      "env": {
        "REDDIT_TIMEOUT": "15.0",
        "REDDIT_LOG_LEVEL": "WARNING"
      }
    },
    "jcodemunch": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "jcodemunch-mcp"
      ],
      "env": {
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
        "JCODEMUNCH_SHARE_SAVINGS": "0"
      }
    }
  }
}